local ChinaHatLines = {}

local function InitChinaHat()
    if not Drawing then return end
    for i=1,3 do
        local ln=Drawing.new("Line")
        ln.Visible=false; ln.Thickness=1.5
        ln.Color=Color3.fromRGB(91,155,255)
        ChinaHatLines[i]=ln
    end
end

local function UpdateLocalChinaHat()
    local function hide()
        for _,l in ipairs(ChinaHatLines) do if l then l.Visible=false end end
    end
    if not Config.ChinaHat or not Config.ChinaHat.Enabled or #ChinaHatLines==0 then hide(); return end

    local char=LocalPlayer.Character
    local head=char and char:FindFirstChild("Head")
    if not head then hide(); return end

    -- Project head top to screen
    local headTop=Vector3.new(head.Position.X, head.Position.Y+head.Size.Y/2+0.1, head.Position.Z)
    local sp,onScreen,depth=Camera:WorldToViewportPoint(headTop)
    if not onScreen or depth<=0 then hide(); return end

    -- Scale hat with distance
    local scale = math.clamp(600/depth, 10, 80)
    local tx,ty  = sp.X, sp.Y
    local hw     = scale * 1.1
    local ht     = scale * 0.9
    local col    = Color3.fromRGB(91,155,255)
    local apex   = Vector2.new(tx,      ty - ht)
    local left   = Vector2.new(tx - hw, ty)
    local right  = Vector2.new(tx + hw, ty)

    ChinaHatLines[1].From=apex;  ChinaHatLines[1].To=left;  ChinaHatLines[1].Color=col; ChinaHatLines[1].Visible=true
    ChinaHatLines[2].From=apex;  ChinaHatLines[2].To=right; ChinaHatLines[2].Color=col; ChinaHatLines[2].Visible=true
    ChinaHatLines[3].From=left;  ChinaHatLines[3].To=right; ChinaHatLines[3].Color=col; ChinaHatLines[3].Visible=true
end

