local function UpdateESP()
    for player,d in pairs(ESPObjects) do
        local char=player.Character
        local hum=char and char:FindFirstChildOfClass("Humanoid")
        local root=char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
        local alive=char and hum and root and hum.Health>0
        local function hideAll()
            for _,dr in pairs(d.Drawings) do if dr and dr.Visible~=nil then pcall(function() dr.Visible=false end) end end
            if d.Highlight then d.Highlight.Parent=nil end
        end
        if not alive or IsTeammate(player) then hideAll(); continue end
        local sp,on,depth=WorldToScreen(root.Position)
        if not on or depth<0 then hideAll(); continue end
        local dist=(Camera.CFrame.Position-root.Position).Magnitude
        local sf=1/(depth*math.tan(math.rad(Camera.FieldOfView/2))*2)*1000
        local bh,bw=sf*4.5,sf*4.5*0.6
        local ec=Config.ESP.ShowTeamColor and GetTeamColor(player) or Config.ESP.BoxColor
        if Config.ESP.Enabled then
            local tl=Vector2.new(sp.X-bw/2,sp.Y-bh/2); local tr=Vector2.new(sp.X+bw/2,sp.Y-bh/2)
            local bl=Vector2.new(sp.X-bw/2,sp.Y+bh/2); local br=Vector2.new(sp.X+bw/2,sp.Y+bh/2)
            local cl=bw*0.25
            local lines={{tl,Vector2.new(tl.X+cl,tl.Y)},{tl,Vector2.new(tl.X,tl.Y+cl)},{tr,Vector2.new(tr.X-cl,tr.Y)},{tr,Vector2.new(tr.X,tr.Y+cl)},{bl,Vector2.new(bl.X+cl,bl.Y)},{bl,Vector2.new(bl.X,bl.Y-cl)},{br,Vector2.new(br.X-cl,br.Y)},{br,Vector2.new(br.X,br.Y-cl)}}
            for i,l in ipairs(lines) do d.Drawings["Box"..i].From=l[1]; d.Drawings["Box"..i].To=l[2]; d.Drawings["Box"..i].Color=ec; d.Drawings["Box"..i].Thickness=Config.ESP.BoxThickness; d.Drawings["Box"..i].Visible=true end
        else
            for i=1,8 do d.Drawings["Box"..i].Visible=false end
        end
        if Config.ESP.Enabled and Config.ESP.ShowName then
            d.Drawings.Name.Text=player.Name; d.Drawings.Name.Position=Vector2.new(sp.X,sp.Y-bh/2-18)
            d.Drawings.Name.Color=Config.ESP.NameColor; d.Drawings.Name.Visible=true
        else d.Drawings.Name.Visible=false end
        if Config.Distance.Enabled then
            d.Drawings.Distance.Text=string.format("[%dm]",math.floor(dist))
            d.Drawings.Distance.Position=Vector2.new(sp.X,sp.Y+bh/2+5)
            d.Drawings.Distance.Color=Config.Distance.Color; d.Drawings.Distance.Visible=dist<=Config.Distance.MaxDistance
        else d.Drawings.Distance.Visible=false end
        if Config.Tracers.Enabled then
            local tc=Config.ESP.ShowTeamColor and GetTeamColor(player) or Config.Tracers.Color
            local from
            if Config.Tracers.Origin=="Bottom" then from=Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y)
            elseif Config.Tracers.Origin=="Center" then from=Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)
            else from=Vector2.new(Mouse.X,Mouse.Y) end
            d.Drawings.Tracer.From=from; d.Drawings.Tracer.To=Vector2.new(sp.X,sp.Y+bh/2)
            d.Drawings.Tracer.Color=tc; d.Drawings.Tracer.Thickness=Config.Tracers.Thickness; d.Drawings.Tracer.Visible=true
        else d.Drawings.Tracer.Visible=false end
        if Config.HealthBar.Enabled then
            local hp=hum.Health/hum.MaxHealth; local bx=sp.X-bw/2-Config.HealthBar.Offset; local by=sp.Y-bh/2
            d.Drawings.HealthBarBG.From=Vector2.new(bx,by); d.Drawings.HealthBarBG.To=Vector2.new(bx,by+bh)
            d.Drawings.HealthBarBG.Color=Color3.fromRGB(0,0,0); d.Drawings.HealthBarBG.Thickness=Config.HealthBar.Width+2; d.Drawings.HealthBarBG.Visible=true
            local hc=Color3.fromRGB(math.floor(255*(1-hp)),math.floor(255*hp),0)
            d.Drawings.HealthBar.From=Vector2.new(bx,by+bh*(1-hp)); d.Drawings.HealthBar.To=Vector2.new(bx,by+bh)
            d.Drawings.HealthBar.Color=hc; d.Drawings.HealthBar.Thickness=Config.HealthBar.Width; d.Drawings.HealthBar.Visible=true
            d.Drawings.HealthText.Text=tostring(math.floor(hum.Health)); d.Drawings.HealthText.Position=Vector2.new(bx,by-12)
            d.Drawings.HealthText.Color=hc; d.Drawings.HealthText.Visible=true
        else d.Drawings.HealthBarBG.Visible=false; d.Drawings.HealthBar.Visible=false; d.Drawings.HealthText.Visible=false end
        if Config.Skeleton.Enabled then
            local sc=Config.ESP.ShowTeamColor and GetTeamColor(player) or Config.Skeleton.Color
            local rt=GetRigType(char); local bones=rt=="R6" and R6Bones or R15Bones
            for i=1,14 do d.Drawings["Skeleton"..i].Visible=false end
            for i,bone in ipairs(bones) do
                local p1=char:FindFirstChild(bone[1]); local p2=char:FindFirstChild(bone[2])
                if p1 and p2 then
                    local s1,v1=WorldToScreen(p1.Position); local s2,v2=WorldToScreen(p2.Position)
                    if v1 and v2 then
                        d.Drawings["Skeleton"..i].From=s1; d.Drawings["Skeleton"..i].To=s2
                        d.Drawings["Skeleton"..i].Color=sc; d.Drawings["Skeleton"..i].Thickness=Config.Skeleton.Thickness; d.Drawings["Skeleton"..i].Visible=true
                    end
                end
            end
        else for i=1,14 do d.Drawings["Skeleton"..i].Visible=false end end
        if Config.Chams.Enabled then
            d.Highlight.Adornee=char; d.Highlight.FillColor=Config.Chams.FillColor
            d.Highlight.OutlineColor=Config.Chams.OutlineColor; d.Highlight.FillTransparency=Config.Chams.FillTransparency
            d.Highlight.OutlineTransparency=Config.Chams.OutlineTransparency; d.Highlight.Parent=char
        else d.Highlight.Parent=nil end
    end
end

