    local id=Config.CustomSky.UseAllSides and FormatAssetId(Config.CustomSky.AllSides) or ""; if id=="" then return end
    pcall(function() sky.SkyboxBk=id; sky.SkyboxDn=id; sky.SkyboxFt=id; sky.SkyboxLf=id; sky.SkyboxRt=id; sky.SkyboxUp=id; sky.CelestialBodiesShown=false end)
