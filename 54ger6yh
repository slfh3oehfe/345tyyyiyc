-- ============================================================
local JumpCircle = nil
local function InitJumpCircle()
    if not Drawing then return end
    JumpCircle = Drawing.new("Circle")
    JumpCircle.Thickness  = 1.5
    JumpCircle.Color      = Color3.fromRGB(91,155,255)
    JumpCircle.Filled     = false
    JumpCircle.Visible    = false
    JumpCircle.Radius     = 1
    JumpCircle.Position   = Vector2.new(0,0)
end

local function UpdateJumpCircle()
    if not JumpCircle or not Config.JumpCircle or not Config.JumpCircle.Enabled then
        if JumpCircle then JumpCircle.Visible=false end; return
    end
    local char=LocalPlayer.Character
    local hrp=char and char:FindFirstChild("HumanoidRootPart")
    local hum=char and char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then JumpCircle.Visible=false; return end

    -- Cast ray straight down to find ground distance
    local origin=hrp.Position
    local ray=workspace:Raycast(origin, Vector3.new(0,-50,0), RaycastParams.new())
    local groundY = ray and ray.Position.Y or (origin.Y - 50)
    local dist=origin.Y - groundY

    -- Project a world-space circle at ground position onto screen
    local groundPos=Vector3.new(origin.X, groundY+0.1, origin.Z)
    local sp,onScreen,depth=Camera:WorldToViewportPoint(groundPos)
    if not onScreen or depth<=0 then JumpCircle.Visible=false; return end

    -- Radius shrinks as player gets closer to ground
    local maxDist=30
    local t2=math.clamp(dist/maxDist,0,1)
    local screenRadius = math.clamp(80*(1-t2*0.6)/depth*40, 8, 120)
    local alpha = math.clamp(1 - dist/maxDist, 0.1, 1)

    JumpCircle.Position = Vector2.new(sp.X, sp.Y)
    JumpCircle.Radius   = screenRadius
    JumpCircle.Color    = Color3.fromRGB(
        math.floor(91  + (255-91) *(1-alpha)),
        math.floor(155 + (80-155)*(1-alpha)),
        math.floor(255 * alpha)
    )
    JumpCircle.Visible  = true
end

