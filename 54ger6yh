local function UpdateShaders()
    local function Apply(nm,cls,props)
        if Config.Shaders[nm].Enabled then
            if not ShaderEffects[nm] then ShaderEffects[nm]=Instance.new(cls); ShaderEffects[nm].Name="NovaV4_"..nm; ShaderEffects[nm].Parent=Lighting end
            for k,v in pairs(props) do pcall(function() ShaderEffects[nm][k]=v end) end
            if ShaderEffects[nm].Enabled~=nil then ShaderEffects[nm].Enabled=true end
        elseif ShaderEffects[nm] then
            if ShaderEffects[nm].Enabled~=nil then ShaderEffects[nm].Enabled=false else pcall(function() ShaderEffects[nm]:Destroy() end) ShaderEffects[nm]=nil end
        end
    end
    Apply("Bloom","BloomEffect",{Intensity=Config.Shaders.Bloom.Intensity,Size=Config.Shaders.Bloom.Size,Threshold=Config.Shaders.Bloom.Threshold})
    Apply("Blur","BlurEffect",{Size=Config.Shaders.Blur.Size})
    Apply("ColorCorrection","ColorCorrectionEffect",{Brightness=Config.Shaders.ColorCorrection.Brightness,Contrast=Config.Shaders.ColorCorrection.Contrast,Saturation=Config.Shaders.ColorCorrection.Saturation,TintColor=Config.Shaders.ColorCorrection.TintColor})
    Apply("SunRays","SunRaysEffect",{Intensity=Config.Shaders.SunRays.Intensity,Spread=Config.Shaders.SunRays.Spread})
    Apply("DepthOfField","DepthOfFieldEffect",{FarIntensity=Config.Shaders.DepthOfField.FarIntensity,FocusDistance=Config.Shaders.DepthOfField.FocusDistance,InFocusRadius=Config.Shaders.DepthOfField.InFocusRadius,NearIntensity=Config.Shaders.DepthOfField.NearIntensity})
    if Config.Shaders.Atmosphere.Enabled then
        if not ShaderEffects.Atmosphere then ShaderEffects.Atmosphere=Instance.new("Atmosphere"); ShaderEffects.Atmosphere.Name="NovaV4_Atmosphere"; ShaderEffects.Atmosphere.Parent=Lighting end
        local a=Config.Shaders.Atmosphere; ShaderEffects.Atmosphere.Density=a.Density; ShaderEffects.Atmosphere.Offset=a.Offset; ShaderEffects.Atmosphere.Color=a.Color; ShaderEffects.Atmosphere.Decay=a.Decay; ShaderEffects.Atmosphere.Glare=a.Glare; ShaderEffects.Atmosphere.Haze=a.Haze
    elseif ShaderEffects.Atmosphere then pcall(function() ShaderEffects.Atmosphere:Destroy() end) ShaderEffects.Atmosphere=nil end
    if Config.Shaders.Fullbright.Enabled then
        if not OriginalLighting.Ambient then OriginalLighting.Ambient=Lighting.Ambient; OriginalLighting.Brightness=Lighting.Brightness; OriginalLighting.OutdoorAmbient=Lighting.OutdoorAmbient end
        Lighting.Ambient=Color3.fromRGB(255,255,255); Lighting.Brightness=2; Lighting.OutdoorAmbient=Color3.fromRGB(255,255,255)
    elseif OriginalLighting.Ambient then Lighting.Ambient=OriginalLighting.Ambient; Lighting.Brightness=OriginalLighting.Brightness; Lighting.OutdoorAmbient=OriginalLighting.OutdoorAmbient end
    if Config.Shaders.NoFog.Enabled then
        if not OriginalLighting.FogEnd then OriginalLighting.FogEnd=Lighting.FogEnd; OriginalLighting.FogStart=Lighting.FogStart end
        Lighting.FogEnd=9999999; Lighting.FogStart=9999999
    elseif OriginalLighting.FogEnd then Lighting.FogEnd=OriginalLighting.FogEnd; Lighting.FogStart=OriginalLighting.FogStart end
    if Config.Shaders.Fog.Enabled then Lighting.FogStart=Config.Shaders.Fog.FogStart; Lighting.FogEnd=Config.Shaders.Fog.FogEnd; Lighting.FogColor=Config.Shaders.Fog.FogColor end
end

local OriginalSkyProperties,CustomSkyInstance=nil,nil
local function FormatAssetId(v)
    if not v or v=="" then return "" end; v=tostring(v):gsub("%s+","")
    if v:find("rbxassetid://") then return v end
    if v:find("roblox.com") then local id=v:match("%d+"); if id then return "rbxassetid://"..id end end
    local id=v:match("%d+"); if id then return "rbxassetid://"..id end; return ""
end
local function UpdateCustomSky()
    if not Config.CustomSky.Enabled then
        if CustomSkyInstance and OriginalSkyProperties then for p,v in pairs(OriginalSkyProperties) do pcall(function() CustomSkyInstance[p]=v end) end end; return
    end
    local sky=Lighting:FindFirstChildOfClass("Sky")
    if not sky then sky=Instance.new("Sky"); sky.Name="NovaV4_Sky"; sky.Parent=Lighting end
    CustomSkyInstance=sky
