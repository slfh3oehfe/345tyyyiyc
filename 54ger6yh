    local _noAnimConn = nil

    local function ApplyNoAnim(on)
        local char = LocalPlayer.Character; if not char then return end
        local hum  = char:FindFirstChildOfClass("Humanoid"); if not hum then return end
        local animate = char:FindFirstChild("Animate")

        if on then
            if animate then animate.Disabled = true end
            -- Try AnimatorEnabled (works on some executors)
            pcall(function() hum.AnimatorEnabled = false end)
            -- Kill existing tracks
            for _, t in ipairs(hum:GetPlayingAnimationTracks()) do
                pcall(function() t:Stop(0) end)
            end
            -- Heartbeat loop: stop every track every frame AND zero their speed
            _noAnimConn = RunService.Heartbeat:Connect(function()
                local c = LocalPlayer.Character; if not c then return end
                local h = c:FindFirstChildOfClass("Humanoid"); if not h then return end
                for _, t in ipairs(h:GetPlayingAnimationTracks()) do
                    pcall(function()
                        t:AdjustSpeed(0)
                        t:Stop(0)
                    end)
                end
                -- Also hit every Animator descendant (tools parent their Animator here)
                for _, v in ipairs(c:GetDescendants()) do
                    if v:IsA("Animator") or v:IsA("AnimationController") then
                        pcall(function()
                            for _, t in ipairs(v:GetPlayingAnimationTracks()) do
                                t:AdjustSpeed(0)
                                t:Stop(0)
                            end
                        end)
                    end
                end
            end)
        else
            if _noAnimConn then _noAnimConn:Disconnect(); _noAnimConn = nil end
            pcall(function() hum.AnimatorEnabled = true end)
            if animate then animate.Disabled = false end
            for _, t in ipairs(hum:GetPlayingAnimationTracks()) do
                pcall(function() t:AdjustSpeed(1) end)
            end
        end
    end

