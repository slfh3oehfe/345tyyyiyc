local function DestroyScript()
    ScriptDestroyed=true
    Config.Aimbot.Enabled=false; Config.Aimbot.ShowFOV=false; Config.CameraFOV.Enabled=false
    Config.Trail.Enabled=false; Config.Particles.Rain.Enabled=false; Config.Particles.Snow.Enabled=false; Config.CustomSky.Enabled=false
    pcall(function() Camera.FieldOfView=OriginalFOV or 70 end); UpdateCustomSky()
    if FOVCircle then pcall(function() FOVCircle:Remove() end) end
    for _,d in pairs(ESPObjects) do
        for _,dr in pairs(d.Drawings) do if dr and dr.Remove then pcall(function() dr:Remove() end) end end
        if d.Highlight then pcall(function() d.Highlight:Destroy() end) end
    end
    ESPObjects={}
    if TrailObject then pcall(function() TrailObject:Destroy() end) end
    if Config.Particles.Rain._part then pcall(function() Config.Particles.Rain._part:Destroy() end) end
    if Config.Particles.Snow._part then pcall(function() Config.Particles.Snow._part:Destroy() end) end
    for _,e in pairs(ShaderEffects) do if e then pcall(function() e:Destroy() end) end end
    for _,c in pairs(Connections) do if c and c.Disconnect then pcall(function() c:Disconnect() end) end end
    if ScreenGui then pcall(function() ScreenGui:Destroy() end) end
end

